---
import { Image, Picture } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { withBase } from '../lib/base';
import {
  heroPhoto,
  iterationStory,
  featuredClip,
  spotlightClips,
  posterFor,
} from '../lib/media';

const pillars = [
  { icon: '⬡', title: 'Shell', body: '5/8-sphere geodesic, translucent panels, a central oculus skylight.' },
  { icon: '⚭', title: 'Move', body: 'Gymnastic rings, a climbing-net loft, wall bars, open floor.' },
  { icon: '❦', title: 'Nourish', body: 'A perimeter kitchen and plants growing along the glazed band.' },
  { icon: '☾', title: 'Rest', body: 'Floor cushions and a round, softly sunken bed.' },
  { icon: '≋', title: 'Bathe', body: 'A freestanding tub, out in the daylight.' },
  { icon: '☀', title: 'Light', body: 'Biophilic daylight from every angle of the dome.' },
];

const featured = iterationStory.slice(0, 3);
---

<Layout title="Home">
  <!-- Hero: the AI concept still leads -->
  <section class="relative overflow-hidden border-b border-line">
    <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-20">
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-clay">
          A geodesic dome home
        </p>
        <h1 class="mt-3 font-display text-4xl leading-[1.05] text-moss-deep sm:text-5xl">
          One big multifunctional room.
        </h1>
        <p class="mt-5 max-w-prose text-lg leading-relaxed text-muted">
          Cook, sleep, bathe, move, and grow plants in a single daylit volume
          under a 5/8-sphere geodesic shell. This is a design study — and an
          honest, cited resource for anyone thinking about building a dome.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={withBase('/design')}
            class="rounded-full bg-moss px-5 py-2.5 text-sm font-semibold text-canvas transition-colors hover:bg-moss-deep"
          >
            See the design →
          </a>
          <a
            href={withBase('/gallery')}
            class="rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-moss-deep transition-colors hover:border-moss"
          >
            Gallery &amp; films
          </a>
        </div>
      </div>

      {
        heroPhoto && (
          <figure class="mx-auto w-full max-w-sm overflow-hidden rounded-panel border border-line bg-surface-2 shadow-md lg:max-w-md">
            <Picture
              src={heroPhoto.image}
              formats={['avif', 'webp']}
              alt={heroPhoto.caption}
              sizes="(min-width: 1024px) 28rem, (min-width: 640px) 24rem, 100vw"
              loading="eager"
              class="w-full object-cover"
            />
            <figcaption class="px-4 py-2 text-xs text-muted">
              AI-generated concept (Grok Imagine).
            </figcaption>
          </figure>
        )
      }
    </div>
  </section>

  <!-- The one-room thesis -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <h2 class="text-center font-display text-2xl text-moss-deep sm:text-3xl">
      Everything a home does — in one room
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-muted">
      No hallways, no wasted rooms. A dome collapses a house into a single
      volume, and every function shares the same daylight.
    </p>
    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        pillars.map((p) => (
          <li class="rounded-panel border border-line bg-surface/60 p-6">
            <span aria-hidden="true" class="text-2xl text-clay">
              {p.icon}
            </span>
            <h3 class="mt-3 text-lg font-semibold text-moss-deep">{p.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted">{p.body}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Concept films — the AI-generated art, front and centre -->
  <section class="border-y border-line bg-moss-deep text-canvas">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-clay">
            Concept films
          </p>
          <h2 class="mt-2 font-display text-2xl text-canvas sm:text-3xl">
            The dome, imagined
          </h2>
          <p class="mt-2 max-w-xl text-sm leading-relaxed text-canvas/70">
            AI-generated concept art and films — "dollhouse" cutaways and slow
            interior fly-throughs of the biophilic one-room dome, made with Grok
            Imagine.
          </p>
        </div>
        <a
          href={withBase('/gallery')}
          class="shrink-0 text-sm font-semibold text-canvas underline underline-offset-4 hover:text-clay"
        >
          All 15 films →
        </a>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-[1.4fr_1fr] lg:items-start">
        <!-- Featured autoplay loop -->
        <figure class="overflow-hidden rounded-panel border border-canvas/15 bg-black/20">
          <video
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={withBase(posterFor(featuredClip.file))}
            class="mx-auto max-h-[34rem] w-full object-contain"
          >
            <source src={withBase(`/videos/${featuredClip.file}`)} type="video/mp4" />
          </video>
        </figure>

        <!-- Spotlight grid (click to play) -->
        <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-2">
          {
            spotlightClips.map((c) => (
              <li class="overflow-hidden rounded-lg border border-canvas/15 bg-black/20">
                <video
                  controls
                  preload="none"
                  playsinline
                  poster={withBase(posterFor(c.file))}
                  class="aspect-[2/3] w-full object-cover"
                >
                  <source src={withBase(`/videos/${c.file}`)} type="video/mp4" />
                </video>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- The 3D studies (honest low-fi work-in-progress) -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="font-display text-2xl text-moss-deep sm:text-3xl">
          The 3D studies
        </h2>
        <p class="mt-2 max-w-xl text-muted">
          Alongside the films, the design was blocked out step by step in
          Blender — rough, low-fi work-in-progress, shown honestly as an
          iteration strip.
        </p>
      </div>
      <a
        href={withBase('/gallery')}
        class="hidden shrink-0 text-sm font-semibold text-moss underline underline-offset-4 sm:inline"
      >
        Full gallery →
      </a>
    </div>
    <ul class="mt-8 grid gap-5 sm:grid-cols-3">
      {
        featured.map((r) => (
          <li class="overflow-hidden rounded-panel border border-line bg-surface/60">
            <Image
              src={r.image}
              alt={r.caption}
              sizes="(min-width: 640px) 33vw, 100vw"
              loading="lazy"
              class="aspect-[16/10] w-full object-cover"
            />
            <p class="px-4 py-3 text-sm text-muted">{r.caption}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Resource CTA -->
  <section class="mx-auto max-w-6xl px-5 pb-16">
    <div class="rounded-panel border border-moss/30 bg-moss/5 p-8 text-center">
      <h2 class="font-display text-2xl text-moss-deep">
        Not selling domes — comparing them
      </h2>
      <p class="mx-auto mt-3 max-w-2xl text-muted">
        Eight build methods weighed honestly on cost, insulation, DIY-ability,
        durability, and the famous dome leak problem — plus a curated directory
        of the best dome projects on the internet.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={withBase('/methods')}
          class="rounded-full bg-moss px-5 py-2.5 text-sm font-semibold text-canvas transition-colors hover:bg-moss-deep"
        >
          Build-method comparison
        </a>
        <a
          href={withBase('/resources')}
          class="rounded-full border border-line bg-canvas px-5 py-2.5 text-sm font-semibold text-moss-deep transition-colors hover:border-moss"
        >
          Resource directory
        </a>
      </div>
    </div>
  </section>
</Layout>
