---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

type Category = CollectionEntry<'projects'>['data']['category'];

const CATEGORY_ORDER: { key: Category; label: string; blurb: string }[] = [
  { key: 'bioceramic', label: 'Bioceramic / next-gen', blurb: 'Emerging materials pushing dome building forward.' },
  { key: 'aircrete', label: 'Aircrete', blurb: 'Cheap, DIY foamed-cement shells and the people building them.' },
  { key: 'geodesic-kit', label: 'Geodesic kits', blurb: 'Buy-a-kit paths — timber, aluminium, polycarbonate, glass, composite.' },
  { key: 'monolithic', label: 'Monolithic / sprayed concrete', blurb: 'Seamless concrete shells — the disaster-resistant end of the spectrum.' },
  { key: 'earthbag', label: 'Earthbag / SuperAdobe', blurb: 'The lowest-cost, most owner-buildable technique.' },
  { key: 'theory', label: 'Fuller & geodesic theory', blurb: 'Where geodesics came from, and the landmarks that made them famous.' },
  { key: 'inspiration', label: 'Inspiration & community', blurb: 'Real builds and encyclopedic hobbyist knowledge.' },
  { key: 'software', label: 'Geometry & software', blurb: 'Calculators, generators, and hub systems for actually building one.' },
];

const projects = await getCollection('projects');
const byCategory = (cat: Category) =>
  projects.filter((p) => p.data.category === cat);
---

<Layout
  title="Resources"
  description="A curated, live-verified directory of the best dome projects on the internet — kits, aircrete, monolithic, earthbag, geodesic theory, and geometry software."
>
  <div class="mx-auto max-w-6xl px-5 py-14">
    <header class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-clay">Directory</p>
      <h1 class="mt-3 font-display text-4xl text-moss-deep">Resources</h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        A curated directory out to the best dome projects on the internet —
        {projects.length} links across {CATEGORY_ORDER.length} categories,
        live-verified as of July 2026. Vendor sites change; if you spot link rot,
        it’s the honest cost of a directory kept out in the open.
      </p>
    </header>

    <nav class="mt-8 flex flex-wrap gap-2 text-sm" aria-label="Categories">
      {
        CATEGORY_ORDER.map((c) => (
          <a
            href={`#${c.key}`}
            class="rounded-full border border-line bg-surface/60 px-3 py-1 text-muted transition-colors hover:border-moss hover:text-moss"
          >
            {c.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-12 space-y-14">
      {
        CATEGORY_ORDER.map((cat) => {
          const items = byCategory(cat.key);
          if (items.length === 0) return null;
          return (
            <section id={cat.key} class="scroll-mt-20">
              <h2 class="font-display text-2xl text-moss-deep">{cat.label}</h2>
              <p class="mt-1 text-sm text-muted">{cat.blurb}</p>
              <ul class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {items.map((project) => (
                  <li>
                    <ProjectCard project={project} />
                  </li>
                ))}
              </ul>
            </section>
          );
        })
      }
    </div>
  </div>
</Layout>
