---
import Layout from '../layouts/Layout.astro';
import Gallery from '../components/Gallery.astro';
import { renders, clips, photos } from '../lib/media';
---

<Layout
  title="Gallery"
  description="AI-generated concept art and films of the one-room dome, plus the Blender 3D studies — the full visual story."
>
  <div class="mx-auto max-w-6xl px-5 py-14">
    <header class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-clay">Gallery</p>
      <h1 class="mt-3 font-display text-4xl text-moss-deep">
        Concept art, films &amp; studies
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        {photos.length} AI concept still{photos.length === 1 ? '' : 's'} and
        {clips.length} AI films (made with Grok Imagine), plus {renders.length}
        Blender 3D studies. The AI art carries the vibe; the renders show the
        honest work-in-progress.
      </p>
    </header>

    <div class="mt-12">
      <Gallery photos={photos} renders={renders} clips={clips} />
    </div>
  </div>
</Layout>
