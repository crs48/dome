---
import { NAV, withBase } from '../lib/base';

const path = Astro.url.pathname.replace(/\/$/, '');
function isActive(href: string): boolean {
  const target = withBase(href).replace(/\/$/, '');
  if (href === '/') return path === target || path === withBase('/').replace(/\/$/, '');
  return path === target || path.startsWith(target + '/');
}
---

<header class="sticky top-0 z-40 border-b border-line bg-canvas/85 backdrop-blur">
  <nav
    class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-5 gap-y-2 px-5 py-3"
    aria-label="Primary"
  >
    <a
      href={withBase('/')}
      class="mr-auto flex items-center gap-2 font-display text-lg font-semibold tracking-tight text-moss-deep"
    >
      <span aria-hidden="true" class="text-clay">◉</span>
      The&nbsp;One-Room&nbsp;Dome
    </a>
    {
      NAV.filter((i) => i.href !== '/').map((item) => (
        <a
          href={withBase(item.href)}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'text-sm transition-colors hover:text-moss',
            isActive(item.href)
              ? 'font-semibold text-moss underline underline-offset-4'
              : 'text-muted',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
